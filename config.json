{
  "name": "Entity Manager",
  "version": "1.1.0",
  "slug": "entity_manager",
  "description": "Manage and standardize Home Assistant entity names",
  "arch": [
    "armhf",
    "armv7",
    "aarch64",
    "amd64",
    "i386"
  ],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 5000,
  "panel_icon": "mdi:rename-box",
  "panel_title": "Entity Manager",
  "homeassistant_api": true,
  "hassio_api": true,
  "hassio_role": "manager",
  "services": [
    "mqtt:need"
  ],
  "host_network": false,
  "ports": {
    "5000/tcp": null
  },
  "ports_description": {
    "5000/tcp": "Web interface (Not required with Ingress)"
  },
  "options": {
    "log_level": "info",
    "enable_disabled_entities": false,
    "enable_z2m_bridge": true,
    "z2m_base_topic": "zigbee2mqtt"
  },
  "schema": {
    "log_level": "list(debug|info|warning|error)?",
    "enable_disabled_entities": "bool?",
    "enable_z2m_bridge": "bool?",
    "z2m_base_topic": "str?"
  },
  "environment": {
    "HA_URL": "http://supervisor/core",
    "HA_TOKEN": "${SUPERVISOR_TOKEN}"
  }
}
